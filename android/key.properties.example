# Android Release Signing Configuration
# 
# INSTRUCTIONS:
# 1. Generate your release keystore:
#    keytool -genkey -v -keystore ~/cykel-release.keystore -alias cykel -keyalg RSA -keysize 2048 -validity 10000
#
# 2. Copy this file to android/key.properties (remove .example)
#
# 3. Fill in your actual values below:

storePassword=YOUR_KEYSTORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=cykel
storeFile=/Users/YOUR_USERNAME/cykel-release.keystore

# SECURITY: Never commit the actual key.properties file to version control!
# It's already added to .gitignore
