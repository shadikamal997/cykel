{
  "name": "cykel-functions",
  "version": "1.0.0",
  "description": "CYKEL Cloud Functions",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "find-user": "node find_my_user.js",
    "test-event": "node test_nearby_event.js"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0",
    "node-iap": "^0.5.5",
    "nodemailer": "^6.9.0",
    "sharp": "^0.33.0",
    "@google-cloud/storage": "^7.7.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "private": true
}
