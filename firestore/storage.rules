rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── User Profile Photos ───────────────────────────────────────────────
    // Authenticated users only — prevents enumeration attacks
    // Owner can read/write/delete their profile photo

    match /users/{userId}/profile.jpg {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024  // 5 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // ── Listing Images ────────────────────────────────────────────────────
    // Authenticated users only — prevents scraping
    // Only the uploader (marketplace/{uid}/...) can write

    match /marketplace/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Legacy path — keep readable for existing listings
    // DEPRECATED: New listings should use /marketplace/{userId}/ path
    // Write disabled for security - old images can only be read
    match /listings/{listingId}/images/{fileName} {
      allow read: if request.auth != null;
      // Disabled write for legacy path - use new path
      allow write: if false;
      allow delete: if false;
    }

    // ── Serial Number Photos ──────────────────────────────────────────────
    // Private — only the owner (uploader) can read/write

    match /listings/{listingId}/serial_photo.jpg {
      allow read: if request.auth != null
        && request.auth.uid == resource.metadata['uploadedBy'];
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── Provider Photos ───────────────────────────────────────────────────
    // Authenticated users only — prevents scraping
    // ProviderId in path must match the document's userId field

    match /providers/{providerId}/photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == providerId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && request.auth.uid == providerId;
    }

    // ── Provider Documents ────────────────────────────────────────────────
    // PRIVATE — only the provider owner and admins can access
    // Used for business registration certificates, VAT docs, etc.

    match /providers/{providerId}/documents/{fileName} {
      allow read: if request.auth != null && (
        request.auth.uid == providerId ||
        request.auth.token.get('role', '') == 'admin'
      );
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024  // 10 MB for documents
        && (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType == 'application/pdf'
        );
      allow delete: if request.auth != null && (
        request.auth.uid == providerId ||
        request.auth.token.get('role', '') == 'admin'
      );
    }

    // ── Location Photos ──────────────────────────────────────────────────
    // Authenticated users only — prevents scraping
    // ProviderId in path = the provider who owns the location

    match /locations/{providerId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == providerId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && request.auth.uid == providerId;
    }

    // ── Event Images ─────────────────────────────────────────────────────
    // Authenticated users only — prevents scraping
    // Only event organizer (userId) can write/delete

    match /events/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── Default: deny everything else ────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
