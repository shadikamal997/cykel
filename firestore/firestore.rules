rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.get('role', '') == 'admin';
    }

    // USERS
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isUser(userId) && request.resource.data.id == userId;
      allow update: if isUser(userId) && request.resource.data.id == userId;
      allow delete: if false;
    }

    // MARKETPLACE
    match /marketplace_listings/{listingId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAuth() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuth() && resource.data.sellerId == request.auth.uid;

      match /reviews/{reviewId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.reviewerId == request.auth.uid;
        allow update, delete: if isAuth() && resource.data.reviewerId == request.auth.uid;
      }
    }

    // EVENTS
    match /events/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.organizerId == request.auth.uid;
      allow update: if isAuth() && resource.data.organizerId == request.auth.uid;
      allow delete: if isAuth() && resource.data.organizerId == request.auth.uid;

      match /participants/{userId} {
        allow read: if isAuth();
        allow create: if isAuth() && isUser(userId);
        allow delete: if isAuth() && isUser(userId);
      }

      match /chat/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
        allow delete: if isAuth() && request.auth.uid == resource.data.senderId;
      }

      match /reviews/{reviewId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.reviewerId == request.auth.uid;
        allow update, delete: if isAuth() && resource.data.reviewerId == request.auth.uid;
      }
    }

    // CONVERSATIONS
    match /conversations/{conversationId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participantIds;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participantIds;
      allow update: if isAuth() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
        allow delete: if isAuth() && request.auth.uid == resource.data.senderId;
      }
    }

    // HAZARDS
    match /hazards/{hazardId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.reportedBy == request.auth.uid;
      allow update: if isAuth() && resource.data.reportedBy == request.auth.uid;
      allow delete: if isAuth() && (resource.data.reportedBy == request.auth.uid || isAdmin());

      match /verifications/{userId} {
        allow read: if isAuth();
        allow create: if isAuth() && isUser(userId);
      }
    }

    // PROVIDERS
    match /providers/{providerId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // LOCATIONS
    match /locations/{locationId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // THEFT ALERTS
    match /theft_alerts/{alertId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.reportedBy == request.auth.uid;
      allow update: if isAuth() && resource.data.reportedBy == request.auth.uid;
      allow delete: if isAuth() && resource.data.reportedBy == request.auth.uid;

      match /sightings/{sightingId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.reportedBy == request.auth.uid;
      }
    }

    // GAMIFICATION
    match /challenges/{challengeId} {
      allow read: if isAuth();
      allow create: if isAuth() && isAdmin();
      allow update, delete: if isAdmin();

      match /participants/{userId} {
        allow read: if isAuth();
        allow create: if isAuth() && isUser(userId);
        allow update: if isAuth() && isUser(userId);
      }
    }

    match /badges/{badgeId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    match /leaderboard/{userId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    match /user_badges/{userId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /user_challenges/{userId} {
      allow read: if isAuth() && isUser(userId);
      allow create, update: if isAuth() && isUser(userId);
    }

    // FAMILY ACCOUNTS
    function isFamilyMember(accountId) {
      let account = get(/databases/$(database)/documents/familyAccounts/$(accountId)).data;
      return request.auth.uid == account.ownerId || request.auth.uid in account.get('memberIds', []);
    }

    match /familyAccounts/{accountId} {
      allow read: if isAuth() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.get('memberIds', []));
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuth() && request.auth.uid == resource.data.ownerId;
      allow delete: if isAuth() && request.auth.uid == resource.data.ownerId;

      match /{document=**} {
        allow read: if isAuth() && isFamilyMember(accountId);
        allow write: if isAuth() && isFamilyMember(accountId);
      }
    }

    match /familyInvitations/{invitationId} {
      allow read: if isAuth() && (request.auth.token.email == resource.data.inviteeEmail || request.auth.uid == resource.data.invitedByUserId);
      allow create: if isAuth() && request.resource.data.invitedByUserId == request.auth.uid;
      allow update: if isAuth() && request.auth.token.email == resource.data.inviteeEmail;
      allow delete: if isAuth() && request.auth.uid == resource.data.invitedByUserId;
    }

    // ROUTES
    match /routes/{routeId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /route_suggestions/{suggestionId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // REPORTS
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && request.resource.data.reportedBy == request.auth.uid;
    }

    // EXPAT HUB - PUBLIC
    match /expatGuides/{guideId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /quickTips/{tipId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /cyclingRules/{ruleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /bikeShops/{shopId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && (resource.data.submittedBy == request.auth.uid || isAdmin());
    }

    match /emergencyContacts/{contactId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /expatRoutes/{routeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // BIKE SHARE
    match /bike_share_stations/{stationId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    match /bike_rentals/{rentalId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // SYSTEM COLLECTIONS
    match /rateLimits/{limitId} {
      allow read: if false;
      allow write: if false;
    }

    match /auditLog/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // USER BIKES
    match /bikes/{bikeId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // SUBSCRIPTIONS & PAYMENTS
    match /subscriptions/{subId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /payments/{paymentId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /paymentMethods/{methodId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // USER SUB-COLLECTIONS
    match /users/{userId}/{document=**} {
      allow read: if isAuth() && isUser(userId);
      allow write: if isAuth() && isUser(userId);
    }

    // BIKE LISTINGS & RENTALS
    match /bikeListings/{listingId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuth() && resource.data.ownerId == request.auth.uid;
      allow delete: if isAuth() && resource.data.ownerId == request.auth.uid;
    }

    match /rentalRequests/{requestId} {
      allow read: if isAuth() && (resource.data.renterId == request.auth.uid || resource.data.ownerId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.renterId == request.auth.uid;
      allow update: if isAuth() && (resource.data.renterId == request.auth.uid || resource.data.ownerId == request.auth.uid);
    }

    match /rentalAgreements/{agreementId} {
      allow read: if isAuth() && (resource.data.renterId == request.auth.uid || resource.data.ownerId == request.auth.uid);
      allow write: if isAuth() && (resource.data.renterId == request.auth.uid || resource.data.ownerId == request.auth.uid);
    }

    match /bikeReviews/{reviewId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.reviewerId == request.auth.uid;
    }

    // BUDDY MATCHING
    match /buddyProfiles/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /buddyMatches/{matchId} {
      allow read: if isAuth() && request.auth.uid in resource.data.userIds;
      allow create: if isAuth() && request.auth.uid in request.resource.data.userIds;
      allow update: if isAuth() && request.auth.uid in resource.data.userIds;
    }

    // ADVANCED ROUTES
    match /advancedRoutes/{routeId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // PROVIDER ANALYTICS
    match /provider_analytics/{providerId} {
      allow read: if isAuth() && (get(/databases/$(database)/documents/providers/$(providerId)).data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // SOCIAL
    match /friendRequests/{requestId} {
      allow read: if isAuth() && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuth() && resource.data.toUserId == request.auth.uid;
      allow delete: if isAuth() && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
    }

    match /socialActivity/{activityId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.actorUid == request.auth.uid;
      allow delete: if isAuth() && resource.data.actorUid == request.auth.uid;
    }

    match /sharedRides/{rideId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuth() && resource.data.ownerUid == request.auth.uid;
      allow delete: if isAuth() && resource.data.ownerUid == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.authorUid == request.auth.uid;
        allow delete: if isAuth() && resource.data.authorUid == request.auth.uid;
      }
    }

    // CROWD HAZARD REPORTS
    match /hazard_reports/{reportId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.reportedBy == request.auth.uid;
      allow update: if isAuth();
      allow delete: if isAuth() && (resource.data.reportedBy == request.auth.uid || isAdmin());
    }

    // INFRASTRUCTURE REPORTS
    match /infrastructure_reports/{reportId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.reportedBy == request.auth.uid;
      allow update: if isAuth() && resource.data.reportedBy == request.auth.uid;
      allow delete: if isAuth() && (resource.data.reportedBy == request.auth.uid || isAdmin());
    }

    // EMERGENCY REPORTS
    match /emergency_reports/{reportId} {
      allow read: if isAuth() && (resource.data.reportedBy == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.reportedBy == request.auth.uid;
    }

    // THEFT REPORTS
    match /theft_reports/{reportId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.reportedBy == request.auth.uid;
      allow update: if isAuth() && resource.data.reportedBy == request.auth.uid;
      allow delete: if isAuth() && resource.data.reportedBy == request.auth.uid;

      match /sightings/{sightingId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.reportedBy == request.auth.uid;
      }
    }

    // MARKETPLACE CHATS
    match /marketplace_chats/{threadId} {
      allow read: if isAuth() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      allow create: if isAuth() && (request.resource.data.buyerId == request.auth.uid || request.resource.data.sellerId == request.auth.uid);
      allow update: if isAuth() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
        allow delete: if isAuth() && resource.data.senderId == request.auth.uid;
      }
    }

    // AGGREGATED RIDES (activity/mobility)
    match /aggregated_rides/{rideId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }
  }
}
