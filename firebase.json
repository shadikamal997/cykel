{
  "firestore": {
    "rules": "firestore/firestore.rules",
    "indexes": "firestore/firestore.indexes.json"
  },
  "storage": {
    "rules": "firestore/storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "cykel-32383",
          "appId": "1:875600194960:android:73e00e095dae785bc09715",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "cykel-32383",
          "appId": "1:875600194960:ios:b8e02980332b7764c09715",
          "uploadDebugSymbols": true,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "cykel-32383",
          "configurations": {
            "android": "1:875600194960:android:73e00e095dae785bc09715",
            "ios": "1:875600194960:ios:b8e02980332b7764c09715"
          }
        }
      }
    }
  },
  "extensions": {
    "firestore-send-email": "firebase/firestore-send-email@0.2.7"
  }
}
