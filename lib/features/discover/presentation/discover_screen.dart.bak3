                      context.go(AppRoutes.map);
                    },
                  ),
                  const SizedBox(height: 24),

                  // ── CYKEL Features ───────────────────────────────────────
                  _SectionHeader(title: context.l10n.cykelFeatures),
                  const SizedBox(height: 12),
                  Row(children: [
                    Expanded(
                      child: _FeatureCard(
                        icon: Icons.pedal_bike_rounded,
                        label: 'Bike Share',
                        color: AppColors.primary,
                        imageUrl: 'assets/images/bikeshare.webp',
                        onTap: () => context.push(AppRoutes.bikeShare),
                      ),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _FeatureCard(
                        icon: Icons.chat_bubble_rounded,
                        label: 'Messages',
                        color: const Color(0xFF5B8DEE),
                        imageUrl: 'assets/images/OIUFKE0.webp',
                        onTap: () => context.push(AppRoutes.messages),
                      ),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _FeatureCard(
                        icon: Icons.family_restroom_rounded,
                        label: 'Family',
                        color: const Color(0xFFE67E22),
                        imageUrl: 'assets/images/eventhero.webp',
                        onTap: () => context.push(AppRoutes.familyGroups),
                      ),
                    ),
                  ]),
                  const SizedBox(height: 12),
                  Row(children: [
                    Expanded(
                      child: _FeatureCard(
                        icon: Icons.people_rounded,
                        label: 'Buddy Match',
                        color: const Color(0xFF9B59B6),
                        imageUrl: 'assets/images/buddymatch.webp',
                        onTap: () => context.push(AppRoutes.buddyMatching),
                      ),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _FeatureCard(
                        icon: Icons.public_rounded,
                        label: 'Expat Hub',
                        color: const Color(0xFF1ABC9C),
                        imageUrl: 'assets/images/medium-shot-people-travel-agency.webp',
                        onTap: () => context.push(AppRoutes.expatHub),
                      ),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _FeatureCard(
                        icon: Icons.event_rounded,
                        label: 'Events',
                        color: const Color(0xFFE74C3C),
                        imageUrl: 'assets/images/mechanic-repairing-bicycle.webp',
                        onTap: () => context.push(AppRoutes.events),
                      ),
                    ),
                  ]),
                  const SizedBox(height: 12),
                  Row(children: [
                    Expanded(
                      child: _FeatureCard(
                        icon: Icons.emoji_events_rounded,
                        label: 'Challenges',
                        color: const Color(0xFFF39C12),
                        imageUrl: 'assets/images/challenges .webp',
                        onTap: () => context.push(AppRoutes.challenges),
                      ),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _FeatureCard(
                        icon: Icons.group_rounded,
                        label: 'Social',
                        color: const Color(0xFF3498DB),
                        imageUrl: 'assets/images/paris-france-city-bicycles-bike-rental-bicycle-parking.webp',
                        onTap: () => context.push(AppRoutes.social),
                      ),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _FeatureCard(
                        icon: Icons.download_rounded,
                        label: 'Offline Maps',
                        color: const Color(0xFF2C3E50),
                        imageUrl: 'assets/images/bikes-rent-street (1).webp',
                        onTap: () => context.push(AppRoutes.offlineMaps),
                      ),
                    ),
                  ]),
                  const SizedBox(height: 24),

                  // ── Nearby ───────────────────────────────────────────────
                  _SectionHeader(
                    title: l10n.sectionNearby,
                    trailing: _userLocation != null
                        ? GestureDetector(
                            onTap: _loadNearby,
                            child: const Icon(Icons.refresh_rounded,
                                size: 18, color: _kPrimaryColor),
                          )
