                          gradientColors: const [Color(0xFF34C759), Color(0xFF30A14E)],
                          onTap: () => _goToProviderList(ProviderType.chargingLocation)),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _CategoryCard(
                          label: l10n.layerRepair,
                          imageUrl: 'assets/images/bike-repair-cable-maintenance-man-workshop-frame-building-professional-engineering-assessment-bicycle-transportation-with-mechanic-technician-startup-restoration.webp',
                          gradientColors: const [Color(0xFFFF9500), Color(0xFFFF6B00)],
                          onTap: () => _goToProviderList(ProviderType.repairShop)),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _CategoryCard(
                          label: l10n.layerShops,
                          imageUrl: 'assets/images/close-up-young-businessman-bike-shop.webp',
                          gradientColors: const [Color(0xFF5856D6), Color(0xFF4339BC)],
                          onTap: () => _goToProviderList(ProviderType.bikeShop)),
                    ),
                  ]),
                  const SizedBox(height: 12),
                  Row(children: [
                    Expanded(
                      child: _CategoryCard(
                          label: l10n.layerService,
                          imageUrl: 'assets/images/mechanic-repairing-bicycle.webp',
                          gradientColors: const [Color(0xFF007AFF), Color(0xFF0051D5)],
                          onTap: () => _goToProviderList(ProviderType.servicePoint)),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _CategoryCard(
                          label: l10n.layerRental,
                          imageUrl: 'assets/images/bikes-rent-street (1).webp',
                          gradientColors: const [Color(0xFFFF2D55), Color(0xFFE5004F)],
                          onTap: () => _goToProviderList(ProviderType.rental)),
                    ),
                    const SizedBox(width: 12),
                    const Expanded(child: SizedBox()), // Empty placeholder
                  ]),
                  const SizedBox(height: 28),

                  // ── CYKEL Verified Providers ─────────────────────────────
                  _SectionHeader(
                    title: l10n.cykelVerifiedProviders,
                    trailing: GestureDetector(
                      onTap: () => _goToMapWithLayer('cykel_repair'),
                      child: Text(l10n.viewAllProviders,
                          style: AppTextStyles.labelSmall
                              .copyWith(color: _kPrimaryColor)),
                    ),
                  ),
                  const SizedBox(height: 12),
                  // Category shortcut cards for CYKEL layers
                  Row(children: [
                    Expanded(
                      child: _CategoryCard(
                          label: l10n.filterCykelRepair,
                          imageUrl: 'assets/images/bike-repair-cable-maintenance-man-workshop-frame-building-professional-engineering-assessment-bicycle-transportation-with-mechanic-technician-startup-restoration.webp',
                          gradientColors: [AppColors.primary.withValues(alpha: 0.8), AppColors.primary],
                          onTap: () => _goToMapWithLayer('cykel_repair')),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _CategoryCard(
                          label: l10n.filterCykelShop,
                          imageUrl: 'assets/images/close-up-young-businessman-bike-shop.webp',
                          gradientColors: [AppColors.primary.withValues(alpha: 0.8), AppColors.primary],
                          onTap: () => _goToMapWithLayer('cykel_shop')),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _CategoryCard(
                          label: l10n.filterCykelCharging,
                          imageUrl: 'assets/images/paris-france-city-bicycles-bike-rental-bicycle-parking.webp',
                          gradientColors: [AppColors.primary.withValues(alpha: 0.8), AppColors.primary],
                          onTap: () => _goToMapWithLayer('cykel_charging')),
                    ),
                  ]),
                  const SizedBox(height: 12),
                  Row(children: [
                    Expanded(
                      child: _CategoryCard(
                          label: l10n.filterCykelService,
                          imageUrl: 'assets/images/man-sitting-grass-his-mountain-bike.webp',
                          gradientColors: [AppColors.primary.withValues(alpha: 0.8), AppColors.primary],
                          onTap: () => _goToMapWithLayer('cykel_service')),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: _CategoryCard(
                          label: l10n.filterCykelRental,
                          imageUrl: 'assets/images/bikes-rent-street (1).webp',
                          gradientColors: [AppColors.primary.withValues(alpha: 0.8), AppColors.primary],
                          onTap: () => _goToMapWithLayer('cykel_rental')),
                    ),
                    const SizedBox(width: 12),
                    const Expanded(child: SizedBox()), // Empty placeholder
                  ]),
                  const SizedBox(height: 28),
                  
                  // ── Nearby Section Header ────────────────────────────────
                  _SectionHeader(
                    title: context.l10n.sectionNearby,
                    trailing: GestureDetector(
                      onTap: () => _goToMapWithLayer('cykel_repair'),
                      child: const Text(
                        'See all',
                        style: TextStyle(
                          fontSize: 14,
                          fontWeight: FontWeight.w600,
