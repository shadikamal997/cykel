        ),
      ),
    );
  }
}

// ─── CYKEL Nearby Providers (Firestore) ───────────────────────────────────────

class _CykelNearbyProviders extends ConsumerWidget {
  const _CykelNearbyProviders({
    required this.userLocation,
    required this.onTap,
  });
  final LatLng? userLocation;
  final void Function(CykelProvider) onTap;

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final approved =
        ref.watch(allApprovedProvidersProvider).valueOrNull ?? [];
    // Filter to show only CYKEL-featured providers (repair shops and charging stations)
    final filtered = approved
        .where((p) =>
            p.isFeatured &&
            (p.providerType == ProviderType.repairShop ||
            p.providerType == ProviderType.chargingLocation))
        .toList();
    if (filtered.isEmpty) {
      return _EmptyCard(
        icon: Icons.store_outlined,
        text: context.l10n.noProvidersNearby,
        description: 'We\'re expanding our network. Check back soon!',
      );
    }
    // Sort by distance (nearest first) & limit to 6.
    final sorted = List<CykelProvider>.from(filtered);
    if (userLocation != null) {
      sorted.sort((a, b) {
        final da = _sqDist(a, userLocation!);
        final db = _sqDist(b, userLocation!);
        return da.compareTo(db);
      });
    }
    final display = sorted.take(6).toList();
    
    return SizedBox(
      height: 240,
      child: ListView.builder(
        padding: const EdgeInsets.symmetric(horizontal: 16),
        scrollDirection: Axis.horizontal,
        itemCount: display.length,
        itemBuilder: (_, i) {
          final p = display[i];
          final distance = userLocation != null 
              ? _calculateDistance(p, userLocation!) 
              : null;
          return _NearbyProviderCard(
            provider: p,
            distance: distance,
            onTap: () => onTap(p),
          );
        },
      ),
    );
  }

  static double _sqDist(CykelProvider p, LatLng loc) {
    final dx = p.latitude - loc.latitude;
    final dy = p.longitude - loc.longitude;
    return dx * dx + dy * dy;
  }

  static double _calculateDistance(CykelProvider p, LatLng userLoc) {
    const R = 6371.0; // Earth radius in km
    const piOver180 = 0.017453292519943295; // pi / 180
    
    final lat1 = userLoc.latitude * piOver180;
    final lat2 = p.latitude * piOver180;
    final dLat = (p.latitude - userLoc.latitude) * piOver180;
    final dLon = (p.longitude - userLoc.longitude) * piOver180;
    
    final a = sin(dLat / 2) * sin(dLat / 2) +
        cos(lat1) * cos(lat2) *
        sin(dLon / 2) * sin(dLon / 2);
    final c = 2 * asin(sqrt(a));
    return R * c;
  }
}

// ─── Nearby Provider Photo Card ──────────────────────────────────────────────

class _NearbyProviderCard extends StatelessWidget {
  const _NearbyProviderCard({
    required this.provider,
    required this.distance,
    required this.onTap,
  });

  final CykelProvider provider;
  final double? distance;
  final VoidCallback onTap;

  @override
  Widget build(BuildContext context) {
    final photoUrl = provider.coverPhotoUrl ?? 
                     (provider.galleryUrls.isNotEmpty ? provider.galleryUrls.first : null);
    
    // Fallback images based on provider type
    final fallbackImage = _getFallbackImage(provider.providerType);
    
    return GestureDetector(
      onTap: onTap,
      child: Container(
        width: 190,
        margin: const EdgeInsets.only(right: 14),
        decoration: BoxDecoration(
          color: Colors.white,
          borderRadius: BorderRadius.circular(18),
          boxShadow: [
            BoxShadow(
              color: Colors.black.withValues(alpha: 0.08),
              blurRadius: 16,
              offset: const Offset(0, 4),
            ),
            BoxShadow(
              color: Colors.black.withValues(alpha: 0.04),
              blurRadius: 8,
              offset: const Offset(0, 2),
            ),
          ],
        ),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            // ── Photo with gradient overlay ──
            ClipRRect(
              borderRadius: const BorderRadius.vertical(top: Radius.circular(18)),
              child: Stack(
                children: [
                  // Photo
                  Container(
                    height: 140,
                    width: double.infinity,
                    decoration: BoxDecoration(
                      color: AppColors.primary.withValues(alpha: 0.1),
                    ),
                    child: photoUrl != null
                        ? CachedImage(
                            imageUrl: photoUrl,
                            height: 140,
                            fit: BoxFit.cover,
                          )
                        : _buildFallbackImage(fallbackImage),
                  ),
                  
                  // Dark gradient overlay for readability
                  Positioned(
                    bottom: 0,
                    left: 0,
                    right: 0,
                    child: Container(
                      height: 60,
                      decoration: BoxDecoration(
                        gradient: LinearGradient(
                          begin: Alignment.topCenter,
                          end: Alignment.bottomCenter,
                          colors: [
                            Colors.transparent,
                            Colors.black.withValues(alpha: 0.6),
                          ],
                        ),
                      ),
                    ),
                  ),
                  
                  // Provider type badge (top-left)
                  Positioned(
                    top: 10,
                    left: 10,
                    child: Container(
                      padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 5),
                      decoration: BoxDecoration(
                        color: Colors.black.withValues(alpha: 0.5),
                        borderRadius: BorderRadius.circular(8),
                      ),
                      child: Row(
                        mainAxisSize: MainAxisSize.min,
                        children: [
                          Icon(
                            _getProviderIcon(provider.providerType),
                            size: 13,
                            color: Colors.white,
                          ),
                        ],
                      ),
                    ),
                  ),
                  
                  // Verified badge (top-right)
                  if (provider.verificationStatus == VerificationStatus.approved)
                    Positioned(
                      top: 10,
                      right: 10,
                      child: Container(
                        padding: const EdgeInsets.all(6),
                        decoration: BoxDecoration(
                          color: AppColors.primary.withValues(alpha: 0.95),
                          borderRadius: BorderRadius.circular(8),
                        ),
                        child: const Icon(
                          Icons.verified_rounded,
                          size: 13,
                          color: Colors.white,
                        ),
                      ),
                    ),
                ],
              ),
            ),
            
            // ── Provider details ──
            Padding(
              padding: const EdgeInsets.all(12),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  // Provider name
                  Text(
                    provider.businessName,
                    style: const TextStyle(
                      fontSize: 15,
                      fontWeight: FontWeight.w700,
                      color: _kPrimaryText,
                      height: 1.2,
                    ),
                    maxLines: 1,
                    overflow: TextOverflow.ellipsis,
                  ),
                  const SizedBox(height: 6),
                  
                  // Rating
                  Row(
                    children: [
                      Icon(
                        Icons.star_rounded,
                        size: 15,
                        color: Colors.amber.shade600,
                      ),
                      const SizedBox(width: 4),
                      Text(
                        provider.rating > 0 
                            ? provider.rating.toStringAsFixed(1) 
                            : '4.5',
                        style: TextStyle(
                          fontSize: 13,
                          fontWeight: FontWeight.w600,
                          color: _kPrimaryText.withValues(alpha: 0.9),
                        ),
                      ),
                      if (provider.reviewCount > 0) ...[
                        Text(
                          ' (${provider.reviewCount})',
                          style: TextStyle(
                            fontSize: 12,
                            color: _kSecondaryText.withValues(alpha: 0.7),
                          ),
                        ),
                      ],
                    ],
                  ),
                  const SizedBox(height: 6),
                  
                  // Distance and estimated time
                  Row(
                    children: [
                      Icon(
                        Icons.location_on_rounded,
                        size: 13,
                        color: AppColors.primary.withValues(alpha: 0.8),
                      ),
                      const SizedBox(width: 3),
                      if (distance != null) ...[
                        Text(
                          '${distance!.toStringAsFixed(1)} km',
                          style: TextStyle(
                            fontSize: 12,
                            fontWeight: FontWeight.w500,
                            color: _kSecondaryText.withValues(alpha: 0.85),
                          ),
                        ),
                        Text(
                          ' • ',
                          style: TextStyle(
                            fontSize: 12,
                            color: _kSecondaryText.withValues(alpha: 0.5),
                          ),
                        ),
                        Icon(
                          Icons.directions_bike_rounded,
                          size: 13,
                          color: AppColors.primary.withValues(alpha: 0.8),
                        ),
                        const SizedBox(width: 3),
                        Text(
                          '${(distance! * 4).round()} min',
                          style: TextStyle(
                            fontSize: 12,
                            fontWeight: FontWeight.w500,
                            color: _kSecondaryText.withValues(alpha: 0.85),
                          ),
                        ),
                      ] else
                        Text(
                          provider.city,
                          style: TextStyle(
                            fontSize: 12,
                            color: _kSecondaryText.withValues(alpha: 0.85),
                          ),
                        ),
                    ],
                  ),
                ],
              ),
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildFallbackImage(String imageUrl) {
    return CachedImage(
      imageUrl: imageUrl,
      height: 140,
      fit: BoxFit.cover,
    );
  }

  String _getFallbackImage(ProviderType type) {
    switch (type) {
      case ProviderType.repairShop:
        return 'https://images.unsplash.com/photo-1544298621-df2f8f9da19d?w=400&q=80';
      case ProviderType.bikeShop:
        return 'https://images.unsplash.com/photo-1485965120184-e220f721d03e?w=400&q=80';
      case ProviderType.chargingLocation:
        return 'https://images.unsplash.com/photo-1617788138017-80ad40651399?w=400&q=80';
      case ProviderType.servicePoint:
        return 'https://images.unsplash.com/photo-1589702140165-d13665f2d0f3?w=400&q=80';
      case ProviderType.rental:
        return 'https://images.unsplash.com/photo-1571068316344-75bc76f77890?w=400&q=80';
    }
  }

  IconData _getProviderIcon(ProviderType t) {
    switch (t) {
      case ProviderType.repairShop:
        return Icons.build_circle_rounded;
      case ProviderType.bikeShop:
        return Icons.store_rounded;
      case ProviderType.chargingLocation:
        return Icons.ev_station_rounded;
      case ProviderType.servicePoint:
        return Icons.handyman_rounded;
      case ProviderType.rental:
        return Icons.pedal_bike_rounded;
    }
  }
}