              ],
            ),
          ),
        ],
      );
}

// ─── GPX Helpers ─────────────────────────────────────────────────────────────

/// Generates a GPX XML string for [ride].
String _gpxFromRide(Ride ride) {
  final sb = StringBuffer();
  sb.writeln('<?xml version="1.0" encoding="UTF-8"?>');
  sb.writeln(
      '<gpx version="1.1" creator="CYKEL" xmlns="http://www.topografix.com/GPX/1/1">');
  sb.writeln('  <trk>');
  sb.writeln('    <name>${ride.dateLabel}</name>');
  sb.writeln('    <trkseg>');
  for (final pt in ride.path) {
    sb.writeln(
        '      <trkpt lat="${pt.latitude}" lon="${pt.longitude}"></trkpt>');
  }
  sb.writeln('    </trkseg>');
  sb.writeln('  </trk>');
  sb.writeln('</gpx>');
  return sb.toString();
}

/// Exports [ride] to a GPX temp file and shows a share/copy sheet.
Future<void> _exportGpx(BuildContext context, Ride ride) async {
  if (ride.path.isEmpty) {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(content: Text(context.l10n.noGpsPathToExport)),
    );
    return;
  }
  final gpx = _gpxFromRide(ride);
  try {
    final dir = Directory.systemTemp;
    final file = File('${dir.path}/cykel_${ride.id}.gpx');
    await file.writeAsString(gpx);
    if (context.mounted) {
      showModalBottomSheet<void>(
        context: context,
        shape: const RoundedRectangleBorder(
            borderRadius: BorderRadius.vertical(top: Radius.circular(20))),
        builder: (_) => _GpxSheet(gpxPath: file.path, gpxContent: gpx),
      );
    }
  } catch (e) {
    if (context.mounted) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text(context.l10n.exportFailed(e.toString()))),
      );
    }
  }
}

class _GpxSheet extends StatelessWidget {
  const _GpxSheet({required this.gpxPath, required this.gpxContent});
  final String gpxPath;
  final String gpxContent;

  @override
  Widget build(BuildContext context) {
    final l10n = context.l10n;
    return Padding(
      padding: const EdgeInsets.all(24),
      child: Column(
        mainAxisSize: MainAxisSize.min,
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Text(l10n.gpxExportTitle, style: AppTextStyles.headline3),
          const SizedBox(height: 8),
          Text(l10n.gpxFileSavedTo(gpxPath),
              style: AppTextStyles.bodySmall
                  .copyWith(color: _kSecondaryText)),
          const SizedBox(height: 16),
          SizedBox(
            width: double.infinity,
            child: ElevatedButton.icon(
              icon: const Icon(Icons.copy_rounded, size: 16),
              label: Text(l10n.copyGpxToClipboard),
              style: ElevatedButton.styleFrom(
                  backgroundColor: _kPrimaryColor,
                  foregroundColor: Colors.white,
                  shape: RoundedRectangleBorder(
                      borderRadius: BorderRadius.circular(12))),
              onPressed: () async {
                await Clipboard.setData(ClipboardData(text: gpxContent));
                if (context.mounted) {
                  Navigator.pop(context);
                  ScaffoldMessenger.of(context).showSnackBar(
                    SnackBar(content: Text(context.l10n.gpxCopiedToClipboard)),
                  );
                }
              },
            ),
          ),
          const SizedBox(height: 8),
        ],
      ),
    );
  }
}
